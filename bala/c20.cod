#include <stdio.h>
#include <string.h>
#include <stdlib.h>
int main()
 {
    char *s;
    s = malloc(1024 * sizeof(char));
    scanf("%[^\n]", s);
    for (int i = 0; i < strlen(s); i++) 
    {
        if (s[i] == ' ') {
            printf("\n"); // Print newline for spaces
        } else {
            printf("%c", s[i]); // Print the character
        }
    }
    
    free(s);
    return 0;
}

